          <boolProp name="LoopController.continue_forever">false</boolProp>
          <intProp name="LoopController.loops">-1</intProp>
        </elementProp>
        <stringProp name="ThreadGroup.num_threads">10</stringProp>
        <stringProp name="ThreadGroup.ramp_time">30</stringProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">false</boolProp>
        <boolProp name="ThreadGroup.scheduler">true</boolProp>
        <stringProp name="ThreadGroup.duration">120</stringProp>
        <stringProp name="ThreadGroup.delay">2</stringProp>
      </ThreadGroup>

      <hashTree>

        <!-- ==================== CHANGE 3: ONCE ONLY CONTROLLER ==================== -->
        <!-- Each thread gets its own JWT token ONCE when it starts -->
        <!-- This is the core of dynamic tokenization -->
        <OnceOnlyController guiclass="OnceOnlyControllerGui" testclass="OnceOnlyController" testname="Dynamic Token - Once Per Thread" enabled="true">
        </OnceOnlyController>

        <hashTree>

          <!-- CHANGE 4: HMAC Signature Generation moved inside main Thread Group -->
          <!-- Each thread generates its own unique signature with its own timestamp -->
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Generate HMAC Signature - Dynamic" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.util.Base64

def appID = vars.get("app_id")
def secret = vars.get("secret")
def version = vars.get("version")
def threadNum = ctx.getThreadNum()

// Generate fresh timestamp for THIS thread
def timestamp = System.currentTimeMillis().toString()
vars.put("timestamp", timestamp)

// Decode base64 secret
def decodedSecret = Base64.getDecoder().decode(secret)

// Build message string
def message = appID + "-" + version + "-" + timestamp

// HMAC-SHA256
Mac mac = Mac.getInstance("HmacSHA256")
SecretKeySpec keySpec = new SecretKeySpec(decodedSecret, "HmacSHA256")
mac.init(keySpec)
byte[] rawHmac = mac.doFinal(message.getBytes("UTF-8"))

// URL safe base64
def signature = Base64.getEncoder().encodeToString(rawHmac)
    .replace("/", "_")
    .replace("+", "-")
    .replace("=", "")

vars.put("signature", signature)
vars.put("need_refresh", "false")

// Store token creation time per thread
vars.put("token_created_at", System.currentTimeMillis().toString())

log.info("=== Thread " + threadNum + " - Dynamic HMAC Generated ===")
log.info("Thread " + threadNum + " Timestamp: " + timestamp)
log.info("Thread " + threadNum + " Signature: " + signature.substring(0, 10) + "...")
            </stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>

          <!-- CHANGE 5: Token HTTP Request moved inside main Thread Group -->
          <!-- Each thread fetches its own JWT token -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST - Get JWT Token (Dynamic)" enabled="true">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{
  "scope": [
    "function:/ReadUboDocument.v1",
    "function:/CreateUboDocument.v1",
    "function:/ReadUboDashboardCases.v1"
  ]
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.domain">${base_url_auth}</stringProp>
            <stringProp name="HTTPSampler.port">443</stringProp>
            <stringProp name="HTTPSampler.protocol">https</stringProp>
            <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
            <stringProp name="HTTPSampler.path">/security/digital/v1/application/token</stringProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
            <stringProp name="HTTPSampler.connect_timeout">10000</stringProp>
            <stringProp name="HTTPSampler.response_timeout">30000</stringProp>
          </HTTPSamplerProxy>

          <hashTree>
            <!-- Token Request Headers -->
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="Token Request Headers" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Content-Type</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">X-Auth-Version</stringProp>
                  <stringProp name="Header.value">${version}</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">X-Auth-AppID</stringProp>
                  <stringProp name="Header.value">${app_id}</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">X-Auth-Signature</stringProp>
                  <stringProp name="Header.value">${signature}</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">X-Auth-Timestamp</stringProp>
                  <stringProp name="Header.value">${timestamp}</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>

            <!-- CHANGE 6: JSON Extractor now saves to thread-local vars (not props) -->
            <!-- Each thread has its own jwt_token variable -->
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="Extract JWT Token - Per Thread" enabled="true">
              <stringProp name="JSONPostProcessor.referenceNames">jwt_token</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.access_token</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">TOKEN_NOT_FOUND</stringProp>
            </JSONPostProcessor>
            <hashTree/>

            <!-- CHANGE 7: NEW PostProcessor - auto detects token key name -->
            <!-- Handles any key name: access_token, token, jwt, etc -->
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Auto Extract Token - Dynamic" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">
def threadNum = ctx.getThreadNum()
def response = prev.getResponseDataAsString()

if (response.contains("eyJ")) {
    def matcher = response =~ /"([^"]+)"\s*:\s*"(eyJ[^"]+)"/
    if (matcher.find()) {
        def tokenKey = matcher.group(1)
        def tokenValue = matcher.group(2)

        // Save token to thread-local variable
        vars.put("jwt_token", tokenValue)

        // Save token creation time for refresh check
        vars.put("token_created_at", System.currentTimeMillis().toString())

        log.info("✅ Thread " + threadNum + " got token via key: " + tokenKey)
        log.info("✅ Thread " + threadNum + " token starts: " + tokenValue.substring(0, 20) + "...")
    }
} else {
    log.error("❌ Thread " + threadNum + " failed to get token!")
    log.error("Response: " + response)
}
              </stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>

            <!-- Token Response Assertion -->
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Assert Token - 200" enabled="true">
              <collectionProp name="Asserion.test_strings">
                <stringProp name="49586">200</stringProp>
              </collectionProp>
              <stringProp name="Assertion.custom_message">Token request failed - Check AppID and Secret</stringProp>
              <stringProp name="Assertion.test_field">Assertion.response_code</stringProp>
              <boolProp name="Assertion.assume_success">false</boolProp>
              <intProp name="Assertion.test_type">8</intProp>
            </ResponseAssertion>
            <hashTree/>

          </hashTree>

        </hashTree>
        <!-- END Once Only Controller -->


        <!-- ==================== CHANGE 8: TOKEN REFRESH CONTROLLER ==================== -->
        <!-- For soak tests - checks if token needs refresh every 45 minutes -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Check Token Expiry - Soak Test" enabled="true">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">
def threadNum = ctx.getThreadNum()
def tokenCreatedAt = vars.get("token_created_at")
def refreshInterval = Long.parseLong(vars.get("token_refresh_interval"))
def currentTime = System.currentTimeMillis()

if (tokenCreatedAt != null) {
    def tokenAge = currentTime - Long.parseLong(tokenCreatedAt)
    def tokenAgeMinutes = tokenAge / 60000

    if (tokenAge > refreshInterval) {
        vars.put("need_refresh", "true")
        log.info("⏰ Thread " + threadNum + " token is " + tokenAgeMinutes + " mins old - REFRESHING")
    } else {
        vars.put("need_refresh", "false")
        log.info("✅ Thread " + threadNum + " token is " + tokenAgeMinutes + " mins old - still valid")
    }
} else {
    vars.put("need_refresh", "false")
}
          </stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Sampler>
        <hashTree/>

        <!-- If Controller - Only refreshes token if expired -->
        <IfController guiclass="IfControllerPanel" testclass="IfController" testname="If Token Needs Refresh" enabled="true">
          <stringProp name="IfController.condition">"${need_refresh}" == "true"</stringProp>
          <boolProp name="IfController.evaluateAll">false</boolProp>
          <boolProp name="IfController.useExpression">false</boolProp>
        </IfController>

        <hashTree>
          <!-- Regenerate HMAC for token refresh -->
          <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="Refresh HMAC Signature" enabled="true">
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="script">
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec
import java.util.Base64

def appID = vars.get("app_id")
def secret = vars.get("secret")
def version = vars.get("version")
def threadNum = ctx.getThreadNum()

def timestamp = System.currentTimeMillis().toString()
vars.put("timestamp", timestamp)

def decodedSecret = Base64.getDecoder().decode(secret)
def message = appID + "-" + version + "-" + timestamp

Mac mac = Mac.getInstance("HmacSHA256")
SecretKeySpec keySpec = new SecretKeySpec(decodedSecret, "HmacSHA256")
mac.init(keySpec)
byte[] rawHmac = mac.doFinal(message.getBytes("UTF-8"))

def signature = Base64.getEncoder().encodeToString(rawHmac)
    .replace("/", "_")
    .replace("+", "-")
    .replace("=", "")

vars.put("signature", signature)
log.info("🔄 Thread " + threadNum + " refreshing token...")
            </stringProp>
            <stringProp name="scriptLanguage">groovy</stringProp>
          </JSR223Sampler>
          <hashTree/>

          <!-- Refresh Token HTTP Request -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="POST - Refresh JWT Token" enabled="true">
